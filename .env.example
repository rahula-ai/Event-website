# ─────────────────────────────────────────────────────────────────────────────
# Dharmasthala Events – Production Environment Variables
# 1. cp .env.example .env
# 2. Fill in every value marked  ← REQUIRED
# 3. chmod 600 .env
# 4. NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production
IMAGE_TAG=latest                        # Docker image tag for deployments

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=dharmasthala.org.in              # ← REQUIRED  (no https://, no www.)
CERTBOT_EMAIL=admin@dharmasthala.org.in # ← REQUIRED  Let's Encrypt notifications

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://dharmasthala.org.in,https://www.dharmasthala.org.in

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=mongoroot               # ← REQUIRED
MONGO_ROOT_PASS=CHANGE_ME_STRONG_PASS  # ← REQUIRED  min 24 chars, random
MONGO_DB=dharmasthala_events
# App-level MongoDB user (created by scripts/mongo-init.js, least-privilege readWrite only)
MONGO_APP_USER=appuser                  # ← REQUIRED if mongo-init.js creates a scoped user
MONGO_APP_PASS=CHANGE_ME_APP_PASS       # ← REQUIRED  min 16 chars, different from root pass
# Full URL built by docker-compose using above vars – override if using Atlas:
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/dharmasthala_events?retryWrites=true&w=majority

# ── Mongo Express (Admin UI) ──────────────────────────────────────────────────
MONGOEXPRESS_USER=meadmin               # ← REQUIRED
MONGOEXPRESS_PASS=CHANGE_ME_ME_PASS    # ← REQUIRED  Access via SSH tunnel

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=events@dharmasthala.org.in   # ← REQUIRED
SMTP_PASS=your_app_password_here       # ← REQUIRED  Gmail App Password (not account pw)
FROM_EMAIL=events@dharmasthala.org.in
ADMIN_EMAIL=admin@dharmasthala.org.in  # ← REQUIRED  Receives contact form submissions

# Alternative SMTP providers (comment out Gmail block above if using these):
# SendGrid relay:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your_sendgrid_api_key
#
# AWS SES (SMTP):
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_USER=AKIAIOSFODNN7EXAMPLE
#   SMTP_PASS=your_ses_smtp_password

# ── Admin API ─────────────────────────────────────────────────────────────────
# Protects GET /api/contact, GET /api/newsletter, GET /api/register
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_API_KEY=CHANGE_ME_TO_RANDOM_48_CHAR_KEY   # ← REQUIRED

# ── Newsletter Integration ────────────────────────────────────────────────────
# Set ONLY ONE service. Leave the rest blank.

# Option A – Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Option B – SendGrid Marketing Campaigns
SENDGRID_API_KEY=
SENDGRID_LIST_ID=

# Option C – Brevo (Sendinblue) — add integration code to main.py
# BREVO_API_KEY=
# BREVO_LIST_ID=

# Option D – Klaviyo — add integration code to main.py
# KLAVIYO_PRIVATE_KEY=
# KLAVIYO_LIST_ID=

# ── Auth Module (Backup) ──────────────────────────────────────────────────────
AUTH_ENABLED=false   # Set to true only when client requests auth
# JWT_SECRET=        # Required if AUTH_ENABLED=true
#                    # Generate: python3 -c "import secrets; print(secrets.token_hex(64))"

# ── GitHub Container Registry (GHCR) ─────────────────────────────────────────
# The server needs this to pull Docker images from GHCR.
# Create at: GitHub → Settings → Developer settings → Personal access tokens
#             → Fine-grained tokens → read:packages permission
# Then add as GitHub Secret named GHCR_READ_TOKEN (not in this file).
# GHCR_READ_TOKEN=github_pat_xxxxxxxxxxxx   ← goes in GitHub Secrets, NOT here
